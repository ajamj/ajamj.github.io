---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Earthquake Early Warning System (EEWS)',
    description: 'Developed ensemble ML-based EEWS prototype with real-time P-wave detection and magnitude estimation using ObsPy and FDSN client. Achieved MAE ≈ 0.42 against BMKG catalog with fastest alert at 24s post-origin time.',
    tags: ['Python', 'ObsPy', 'Machine Learning', 'Seismic Processing'],
  },
  {
    title: 'Thesis: ML-Based Earthquake Parameter Estimation',
    description: 'Performance evaluation of ensemble ML-based early warning system analyzing input duration and station location effects on model generalization using real seismic data from BMKG catalog.',
    tags: ['Python', 'Machine Learning', 'Seismic Analysis'],
  },
  {
    title: 'Real-time Seismic Monitoring Dashboard',
    description: 'PyQt5 GUI with Folium-based real-time mapping and Telegram Bot API for automated earthquake alerts at BMKG.',
    tags: ['Python', 'PyQt5', 'Folium', 'Telegram API'],
  },
];

const skills = [
  { 
    category: 'Programming', 
    items: ['Python', 'Bash', 'SQL', 'MATLAB'],
  },
  { 
    category: 'Seismic & Geophysical Tools', 
    items: ['ObsPy', 'SeisComP', 'Waveform Visualization', 'Phase Picking', 'SEED/MiniSEED'],
  },
  { 
    category: 'Languages', 
    items: ['Indonesian (Native)', 'English (Professional)'],
  },
];

const experience = [
  {
    title: 'Earthquake Early Warning System Prototype Development',
    organization: 'BMKG (Badan Meteorologi, Klimatologi, dan Geofisika)',
    period: 'Feb 2024 – Jun 2024',
    description: 'Internship developing ML-based earthquake early warning system for Indonesia\'s national seismic monitoring network.',
  },
  {
    title: 'Computational Methods Course Lab Assistant',
    organization: 'Universitas Gadjah Mada',
    period: 'Aug 2023 – Jan 2024',
    description: 'Mentored 50+ undergraduate students in Python programming for scientific computing.',
  },
];

const achievements = [
  '3rd Place, Three-Minute Thesis (3MT) Competition, UGM Faculty of Math & Natural Sciences (2025)',
  'Earthquake Preparedness Pocket Book for Elementary School Students (2025)',
  'SeisComP Software Training – End-to-end seismic data processing (2024)',
  'Perintis Scholarship Recipient (2018)',
];
---

<Layout title="Ajam Jamaludin | Geophysics Researcher">
  <section id="about">
    <h1>Ajam Jamaludin</h1>
    <p class="subtitle">Junior Geophysics Researcher</p>
    <p class="location">Yogyakarta, Indonesia</p>
    
    <h2>About Me</h2>
    <p>
      Geophysics graduate from Universitas Gadjah Mada with experience in evaluating machine learning systems for geophysical applications, particularly seismic signal processing and earthquake early warning. Skilled in building Python-based data pipelines for preprocessing, feature extraction, and performance validation of ML models under realistic conditions.
    </p>
    <p>
      Strong foundation in signal processing, statistical analysis, and scientific computing. Eager to expand expertise into deep learning applications in geophysics, leveraging domain knowledge and research-oriented mindset.
    </p>

    <h2>Education</h2>
    <div class="education-card">
      <h3>Bachelor of Science in Geophysics</h3>
      <p class="gpa">GPA: 3.35</p>
      <p class="institution">Universitas Gadjah Mada, Sleman, Indonesia</p>
      <p class="period">2019 – 2026</p>
      <p class="thesis">
        <strong>Thesis:</strong> Performance Evaluation of Earthquake Parameter Estimation in an Ensemble Machine Learning-Based Early Warning System: Analysis of Input Duration and Station Location Effects on Model Generalization
      </p>
    </div>

    <h2>Experience</h2>
    <div class="experience-list">
      {experience.map((exp) => (
        <article class="experience-card">
          <h3>{exp.title}</h3>
          <p class="org">{exp.organization}</p>
          <p class="period">{exp.period}</p>
          <p>{exp.description}</p>
        </article>
      ))}
    </div>

    <h2>Achievements</h2>
    <ul class="achievements-list">
      {achievements.map((item) => (
        <li>{item}</li>
      ))}
    </ul>
  </section>

  <section id="projects">
    <h2>Projects</h2>
    <div class="projects-grid">
      {projects.map((project) => (
        <article class="project-card">
          <h3>{project.title}</h3>
          <p>{project.description}</p>
          <div class="tags">
            {project.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="skills">
    <h2>Skills</h2>
    <div class="skills-grid">
      {skills.map((skillGroup) => (
        <div class="skill-group">
          <h3>{skillGroup.category}</h3>
          <ul>
            {skillGroup.items.map((item) => (
              <li>{item}</li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </section>

  <section id="contact">
    <h2>Contact</h2>
    <p>Interested in collaboration or have questions? Feel free to reach out.</p>
    <div class="contact-links">
      <a href="mailto:jamaludinajam@gmail.com" class="contact-link">
        <span>Email</span>
      </a>
      <a href="https://linkedin.com/in/ajam-jamaludin-56599a202" target="_blank" rel="noopener noreferrer" class="contact-link">
        <span>LinkedIn</span>
      </a>
      <a href="https://github.com/ajamj" target="_blank" rel="noopener noreferrer" class="contact-link">
        <span>GitHub</span>
      </a>
    </div>
  </section>
</Layout>

<style>
  #about h1 {
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .subtitle {
    font-size: 1.25rem;
    color: var(--color-text);
    opacity: 0.8;
    margin-bottom: var(--space-xs);
  }

  .location {
    font-size: 0.875rem;
    color: var(--color-text);
    opacity: 0.6;
    margin-bottom: var(--space-xl);
  }

  #about h2 {
    border-bottom: 3px solid var(--color-accent);
    display: inline-block;
    padding-bottom: var(--space-xs);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-lg);
  }

  .education-card,
  .experience-card {
    background: #FFFFFF;
    padding: var(--space-lg);
    border-radius: 8px;
    border: 1px solid #e5e5e5;
    margin-bottom: var(--space-lg);
  }

  .education-card h3,
  .experience-card h3 {
    color: var(--color-accent);
    margin-bottom: var(--space-xs);
  }

  .gpa {
    font-weight: 600;
    color: var(--color-accent-secondary);
  }

  .institution {
    font-style: italic;
    opacity: 0.8;
  }

  .period {
    font-size: 0.875rem;
    opacity: 0.6;
  }

  .thesis {
    margin-top: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid #e5e5e5;
  }

  .org {
    font-weight: 500;
    color: var(--color-text);
    opacity: 0.9;
  }

  .achievements-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .achievements-list li {
    padding: var(--space-sm) 0;
    border-bottom: 1px solid #e5e5e5;
    padding-left: var(--space-lg);
    position: relative;
  }

  .achievements-list li:before {
    content: '▸';
    position: absolute;
    left: 0;
    color: var(--color-accent);
  }

  .achievements-list li:last-child {
    border-bottom: none;
  }

  .projects-grid {
    display: grid;
    gap: var(--space-lg);
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  .project-card {
    background: #FFFFFF;
    padding: var(--space-lg);
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    border: 1px solid #e5e5e5;
  }

  .project-card h3 {
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: var(--space-md);
  }

  .tag {
    background: var(--color-accent);
    color: #FFFFFF;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 500;
  }

  .skills-grid {
    display: grid;
    gap: var(--space-xl);
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  }

  .skill-group h3 {
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .skill-group ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .skill-group li {
    padding: var(--space-xs) 0;
    border-bottom: 1px solid #e5e5e5;
  }

  .skill-group li:last-child {
    border-bottom: none;
  }

  .contact-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-md);
    margin-top: var(--space-lg);
  }

  .contact-link {
    display: inline-flex;
    align-items: center;
    padding: var(--space-sm) var(--space-lg);
    background: var(--color-accent);
    color: #FFFFFF;
    border-radius: 6px;
    font-weight: 500;
    transition: background-color 0.2s ease;
  }

  .contact-link:hover {
    background: var(--color-accent-secondary);
    color: #FFFFFF;
  }

  .contact-link:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  section h2 {
    border-bottom: 3px solid var(--color-accent);
    display: inline-block;
    padding-bottom: var(--space-xs);
    margin-bottom: var(--space-xl);
  }
</style>
