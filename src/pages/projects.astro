---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'Seismic EEW Pipeline',
    description: 'Real-time earthquake early warning data pipeline processing 58-station seismic network data. Features optimized STA/LTA P-wave detection, magnitude estimation using Mpd method, and hypocenter calculation via HYPO71 integration.',
    tags: ['Python', 'ObsPy', 'FDSN', 'PyQt5', 'Folium'],
    year: '2024',
    category: 'Infrastructure',
    links: [
      { label: 'View Code', url: 'https://github.com/ajamj/seismic-pipeline' },
    ],
  },
  {
    title: 'Seismogram Visualizer',
    description: 'Interactive web application for visualizing seismic waveforms with real-time data fetching from FDSN networks. Features waveform display, filtering controls, and travel-time calculations.',
    tags: ['JavaScript', 'D3.js', 'FDSN', 'Web APIs'],
    year: '2024',
    category: 'Visualization',
    links: [
      { label: 'Live Demo', url: 'https://ajamj.github.io/seismogram' },
      { label: 'View Code', url: 'https://github.com/ajamj/seismogram' },
    ],
  },
  {
    title: 'Earthquake Knowledge Graph',
    description: 'Automated system for extracting and indexing seismic metadata into a structured knowledge graph. Enables advanced querying of earthquake catalogs and pattern analysis across historical seismic data.',
    tags: ['Python', 'Knowledge Graph', 'RDF', 'SPARQL'],
    year: '2024',
    category: 'Data Science',
    links: [
      { label: 'View Code', url: 'https://github.com/ajamj/earthquake-kg' },
    ],
  },
  {
    title: 'ML Earthquake Classifier',
    description: 'Machine learning-based system for earthquake detection and classification using ensemble methods. Evaluates different ML approaches for P-wave detection and magnitude prediction.',
    tags: ['Python', 'Scikit-learn', 'TensorFlow', 'ObsPy'],
    year: '2024',
    category: 'Machine Learning',
    links: [
      { label: 'View Code', url: 'https://github.com/ajamj/ml-earthquake' },
    ],
  },
  {
    title: 'Seismic Data Processing Scripts',
    description: 'Collection of Python scripts for seismic data processing including filtering, spectral analysis, and ground motion calculations using ObsPy.',
    tags: ['Python', 'ObsPy', 'NumPy', 'SciPy'],
    year: '2023',
    category: 'Tools',
    links: [
      { label: 'View Code', url: 'https://github.com/ajamj/seismic-scripts' },
    ],
  },
  {
    title: 'Gravitational Terrain Correction Tool',
    description: 'Interactive GUI application for calculating gravitational terrain corrections using digital elevation models. Built for geophysics surveys.',
    tags: ['Python', 'MATLAB', 'GDAL', 'Tkinter'],
    year: '2023',
    category: 'Tools',
    links: [
      { label: 'View Code', url: 'https://github.com/ajamj/grav-terrain' },
    ],
  },
];
---

<Layout 
  title="Projects — Ajam Jamaludin"
  description="Research projects and software tools by Ajam Jamaludin in computational seismology"
>
  <main>
    <section class="projects-hero">
      <div class="container">
        <div class="accent-bar"></div>
        <span class="page-label">Projects</span>
        <h1>Selected Research & Software</h1>
        <p class="hero-intro">
          A collection of projects spanning earthquake early warning systems, seismic data visualization, machine learning for earthquake detection, and geophysical computation tools.
        </p>
      </div>
    </section>

    <section class="projects-list">
      <div class="container">
        {projects.map((project) => (
          <article class="card project-card">
            <div class="project-header">
              <div>
                <h2>{project.title}</h2>
                <span class="project-category">{project.category} · {project.year}</span>
              </div>
            </div>
            <p class="project-description">{project.description}</p>
            <div class="project-footer">
              <div class="tags">
                {project.tags.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <div class="project-links">
                {project.links.map((link) => (
                  <a href={link.url} class="project-link" target="_blank" rel="noopener noreferrer">
                    {link.label}
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                      <path d="M7 17L17 7M17 7H7M17 7V17"/>
                    </svg>
                  </a>
                ))}
              </div>
            </div>
          </article>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .projects-hero {
    padding-top: calc(80px + var(--space-2xl));
    padding-bottom: var(--space-2xl);
  }

  .page-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .projects-hero h1 {
    margin-bottom: var(--space-lg);
  }

  .hero-intro {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  .accent-bar {
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .projects-list {
    padding-top: 0;
  }

  .project-card {
    margin-bottom: var(--space-lg);
  }

  .project-header h2 {
    font-size: 1.25rem;
    margin: 0 0 var(--space-xs);
  }

  .project-category {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .project-description {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    margin: var(--space-md) 0;
  }

  .project-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: var(--space-md);
    padding-top: var(--space-md);
    border-top: 1px solid var(--color-border-light);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    border-radius: 100px;
    letter-spacing: 0.01em;
  }

  .project-links {
    display: flex;
    gap: var(--space-md);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
    text-decoration: none;
  }

  .project-link:hover {
    text-decoration: underline;
  }

  .project-link svg {
    opacity: 0.5;
  }
</style>
