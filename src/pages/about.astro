---
import Layout from '../layouts/Layout.astro';
import PublicationList from '../components/PublicationList.astro';
import SkillsChart from '../components/SkillsChart.astro';

const education = [
  {
    degree: 'Bachelor of Science in Geophysics',
    institution: 'Universitas Gadjah Mada',
    period: '2019 – 2026',
    details: [
      'GPA: 3.35 / 4.00',
      'Specialization: Signal Processing, Statistical Analysis, Scientific Computing',
    ],
  },
];

const researchInterests = [
  {
    title: 'Seismic Data Processing',
    description: 'Developing automated algorithms for earthquake detection, phase picking, and magnitude estimation using machine learning approaches.',
  },
  {
    title: 'Earthquake Early Warning Systems',
    description: 'Building real-time seismic monitoring pipelines with optimized parameter estimation for rapid and accurate hazard assessment.',
  },
  {
    title: 'Seismic Hazard Analysis',
    description: 'Analyzing ground motion characteristics and probabilistic seismic hazard modeling for infrastructure resilience.',
  },
  {
    title: 'Knowledge Graph Integration',
    description: 'Connecting seismic metadata into structured knowledge systems for enhanced data discovery and analysis.',
  },
];

const timeline = [
  {
    year: '2026',
    title: 'Research Assistant',
    organization: 'Geoseismal Research Center',
    description: 'Continuing seismic research with focus on computational methods and real-time data processing pipelines.',
  },
  {
    year: '2024',
    title: 'Software Intern',
    organization: 'BMKG',
    description: 'Developed EEW data pipelines and magnitude estimation algorithms for Indonesia\'s seismic network.',
  },
  {
    year: '2023',
    title: 'Teaching Assistant',
    organization: 'UGM',
    description: 'Mentored undergraduates in Python for scientific computing and computational methods.',
  },
  {
    year: '2019',
    title: 'Began Studies',
    organization: 'Universitas Gadjah Mada',
    description: 'Started undergraduate journey in geophysics.',
  },
];
---

<Layout 
  title="About — Ajam Jamaludin"
  description="Extended biography and research interests of Ajam Jamaludin, Geophysics Researcher"
>
  <main>
    <!-- Hero Section -->
    <section class="about-hero">
      <div class="container">
        <div class="accent-bar"></div>
        <span class="page-label">About</span>
        <h1>Geophysics Researcher</h1>
        <p class="hero-intro">
          I'm a geophysics researcher focused on seismic data analysis, earthquake early warning systems, and computational methods for real-time hazard assessment. My work bridges signal processing, machine learning, and domain expertise to build reliable systems for earthquake monitoring.
        </p>
      </div>
    </section>

    <!-- Research Interests -->
    <section class="research-interests">
      <div class="container">
        <h2>Research Interests</h2>
        <div class="interests-grid">
          {researchInterests.map((interest) => (
            <div class="card interest-card">
              <h3>{interest.title}</h3>
              <p>{interest.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Education -->
    <section class="education-section">
      <div class="container">
        <h2>Education</h2>
        {education.map((edu) => (
          <div class="card education-card">
            <div class="edu-header">
              <h3>{edu.degree}</h3>
              <span class="edu-period">{edu.period}</span>
            </div>
            <p class="edu-institution">{edu.institution}</p>
            <ul class="edu-details">
              {edu.details.map((detail) => (
                <li>{detail}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Timeline -->
    <section class="timeline-section">
      <div class="container">
        <h2>Career Timeline</h2>
        <div class="timeline">
          {timeline.map((item, i) => (
            <div class="timeline-item">
              <div class="timeline-year">{item.year}</div>
              <div class="timeline-content">
                <h3>{item.title}</h3>
                <p class="timeline-org">{item.organization}</p>
                <p>{item.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .about-hero {
    padding-top: calc(80px + var(--space-2xl));
    padding-bottom: var(--space-2xl);
  }

  .page-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .about-hero h1 {
    margin-bottom: var(--space-lg);
  }

  .hero-intro {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    max-width: 600px;
  }

  .accent-bar {
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .research-interests h2,
  .education-section h2,
  .timeline-section h2 {
    margin-bottom: var(--space-xl);
  }

  .interests-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-lg);
  }

  .interest-card h3 {
    font-size: 1.125rem;
    margin-bottom: var(--space-sm);
  }

  .interest-card p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  .education-card {
    margin-bottom: var(--space-lg);
  }

  .edu-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-xs);
  }

  .edu-header h3 {
    font-size: 1.125rem;
    margin: 0;
  }

  .edu-period {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .edu-institution {
    font-weight: 500;
    margin-bottom: var(--space-sm);
  }

  .edu-details {
    margin: 0;
    padding-left: var(--space-lg);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .edu-details li {
    margin-bottom: var(--space-xs);
  }

  .timeline {
    position: relative;
    padding-left: var(--space-xl);
  }

  .timeline::before {
    content: '';
    position: absolute;
    left: 6px;
    top: 0;
    bottom: 0;
    width: 1px;
    background: var(--color-border);
  }

  .timeline-item {
    position: relative;
    padding-bottom: var(--space-xl);
  }

  .timeline-item::before {
    content: '';
    position: absolute;
    left: calc(-1 * var(--space-xl) + 2px);
    top: 6px;
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--color-accent);
    border: 2px solid var(--color-bg);
  }

  .timeline-year {
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--color-accent);
    letter-spacing: 0.05em;
    margin-bottom: var(--space-xs);
  }

  .timeline-content h3 {
    font-size: 1.0625rem;
    margin: 0 0 var(--space-xs);
  }

  .timeline-org {
    font-weight: 500;
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0 0 var(--space-sm);
  }

  .timeline-content p {
    font-size: 0.9375rem;
    color: var(--color-text-muted);
    margin: 0;
  }

  @media (max-width: 640px) {
    .edu-header {
      flex-direction: column;
      gap: 0;
    }
  }
</style>
