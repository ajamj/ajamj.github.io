---
import Layout from '../layouts/Layout.astro';

const experience = [
  {
    title: 'Research Assistant',
    organization: 'Geoseismal Research Center',
    location: 'Yogyakarta, Indonesia',
    period: 'Feb 2026 – Present',
    highlights: [
      'Conducting geophysics research with focus on seismic data analysis and interpretation.',
      'Developing Python-based data pipelines for real-time waveform processing using ObsPy.',
      'Automating seismic metadata extraction and indexing into a knowledge graph system.',
    ],
  },
  {
    title: 'Geophysics Software Intern — Earthquake Early Warning Systems',
    organization: 'BMKG (Badan Meteorologi, Klimatologi, dan Geofisika)',
    location: 'Jakarta, Indonesia',
    period: 'Feb 2024 – Jun 2024',
    highlights: [
      'Engineered end-to-end data pipelines in Python (ObsPy, FDSN client) to ingest, process, and analyze 58-station seismic data in real time.',
      'Optimized recursive STA/LTA parameters for P-wave detection, significantly reducing false triggers under noisy field conditions.',
      'Implemented magnitude estimation using the Mpd method, achieving MAE ≈ 0.42.',
      'Integrated HYPO71 for hypocenter calculation and developed PyQt5 GUI with Folium-based real-time mapping.',
    ],
  },
  {
    title: 'Laboratory Teaching Assistant — Computational Methods',
    organization: 'Universitas Gadjah Mada',
    location: 'Yogyakarta, Indonesia',
    period: 'Aug 2023 – Jan 2024',
    highlights: [
      'Mentored 50+ undergraduate students in Python programming for scientific computing.',
      'Developed hands-on practicum on building interactive regression tools using Tkinter.',
      'Evaluated student work with rubric-based feedback emphasizing reproducibility and code readability.',
    ],
  },
];

const education = [
  {
    degree: 'Bachelor of Science in Geophysics',
    institution: 'Universitas Gadjah Mada',
    location: 'Yogyakarta, Indonesia',
    period: '2019 – 2026',
    details: [
      'GPA: 3.35 / 4.00',
      'Thesis: "Performance Evaluation of Earthquake Parameter Estimation in an Ensemble Machine Learning-Based Early Warning System"',
      'Specialization: Signal Processing, Statistical Analysis, Scientific Computing',
      'Relevant coursework: Seismology, Gravity & Magnetic Methods, Remote Sensing, Numerical Methods',
    ],
  },
];

const skills = [
  {
    category: 'Programming Languages',
    items: ['Python', 'MATLAB', 'R', 'SQL', 'JavaScript'],
  },
  {
    category: 'Seismology & Geophysics',
    items: ['ObsPy', 'FDSN', 'HYPO71', 'SAC', 'GMT'],
  },
  {
    category: 'Data Science & ML',
    items: ['NumPy', 'SciPy', 'Scikit-learn', 'TensorFlow', 'Pandas'],
  },
  {
    category: 'Tools & Platforms',
    items: ['Git', 'Linux', 'Docker', 'PostgreSQL', 'D3.js'],
  },
];
---

<Layout 
  title="CV — Ajam Jamaludin"
  description="Curriculum vitae and professional experience of Ajam Jamaludin"
>
  <main>
    <section class="cv-hero">
      <div class="container">
        <div class="accent-bar"></div>
        <span class="page-label">Curriculum Vitae</span>
        <h1>Ajam Jamaludin</h1>
        <p class="hero-intro">
          Geophysics Researcher specializing in computational seismology and earthquake early warning systems.
        </p>
        <a href="/Ajam-Jamaludin-CV.pdf" download class="btn btn--primary">
          Download PDF
          <svg width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 3v12m0 0l-4-4m4 4l4-4M4 21h16"/>
          </svg>
        </a>
      </div>
    </section>

    <!-- Experience -->
    <section class="cv-section">
      <div class="container">
        <h2>Experience</h2>
        {experience.map((exp) => (
          <div class="cv-entry">
            <div class="cv-entry-header">
              <div>
                <h3>{exp.title}</h3>
                <p class="cv-org">{exp.organization}</p>
              </div>
              <div class="cv-meta">
                <span class="cv-period">{exp.period}</span>
                <span class="cv-location">{exp.location}</span>
              </div>
            </div>
            <ul class="cv-highlights">
              {exp.highlights.map((h) => (
                <li>{h}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Education -->
    <section class="cv-section">
      <div class="container">
        <h2>Education</h2>
        {education.map((edu) => (
          <div class="cv-entry">
            <div class="cv-entry-header">
              <div>
                <h3>{edu.degree}</h3>
                <p class="cv-org">{edu.institution}</p>
              </div>
              <div class="cv-meta">
                <span class="cv-period">{edu.period}</span>
                <span class="cv-location">{edu.location}</span>
              </div>
            </div>
            <ul class="cv-highlights">
              {edu.details.map((d) => (
                <li>{d}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </section>

    <!-- Skills -->
    <section class="cv-section">
      <div class="container">
        <h2>Technical Skills</h2>
        <div class="skills-grid">
          {skills.map((group) => (
            <div class="skill-group">
              <h3>{group.category}</h3>
              <div class="skill-items">
                {group.items.map((item) => (
                  <span class="tag">{item}</span>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .cv-hero {
    padding-top: calc(80px + var(--space-2xl));
    padding-bottom: var(--space-2xl);
  }

  .page-label {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .cv-hero h1 {
    margin-bottom: var(--space-lg);
  }

  .hero-intro {
    font-size: 1.125rem;
    line-height: 1.8;
    color: var(--color-text-muted);
    max-width: 600px;
    margin-bottom: var(--space-xl);
  }

  .accent-bar {
    width: 32px;
    height: 2px;
    background: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .cv-section {
    padding-top: 0;
  }

  .cv-section h2 {
    margin-bottom: var(--space-xl);
    padding-bottom: var(--space-sm);
    border-bottom: 1px solid var(--color-border);
  }

  .cv-entry {
    padding: var(--space-lg) 0;
    border-bottom: 1px solid var(--color-border-light);
  }

  .cv-entry:last-child {
    border-bottom: none;
  }

  .cv-entry-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    flex-wrap: wrap;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }

  .cv-entry h3 {
    font-size: 1.0625rem;
    margin: 0 0 var(--space-xs);
  }

  .cv-org {
    font-weight: 500;
    font-size: 0.9375rem;
    margin: 0;
  }

  .cv-meta {
    text-align: right;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .cv-period {
    font-size: 0.8125rem;
    font-weight: 500;
    color: var(--color-accent);
  }

  .cv-location {
    font-size: 0.8125rem;
    color: var(--color-text-muted);
  }

  .cv-highlights {
    margin: 0;
    padding-left: var(--space-lg);
    font-size: 0.9375rem;
    color: var(--color-text-muted);
  }

  .cv-highlights li {
    margin-bottom: var(--space-sm);
    line-height: 1.7;
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: var(--space-xl);
  }

  .skill-group h3 {
    font-size: 0.9375rem;
    font-weight: 600;
    margin: 0 0 var(--space-md);
    font-family: var(--font-body);
  }

  .skill-items {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    font-size: 0.75rem;
    font-weight: 500;
    padding: 0.25rem 0.625rem;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    border-radius: 100px;
    letter-spacing: 0.01em;
  }

  @media (max-width: 640px) {
    .cv-entry-header {
      flex-direction: column;
    }

    .cv-meta {
      text-align: left;
      flex-direction: row;
      gap: var(--space-md);
    }
  }
</style>
