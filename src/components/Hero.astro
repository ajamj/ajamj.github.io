---
---

<section id="hero" class="hero-section">
  <div class="hero-inner">
    <!-- Subtle waveform motif -->
    <svg class="hero-waveform" viewBox="0 0 800 60" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,30 C40,30 60,10 100,30 C140,50 160,30 200,30 C240,30 260,10 300,30 C340,50 360,30 400,30 C440,30 460,10 500,30 C540,50 560,30 600,30 C640,30 660,10 700,30 C740,50 760,30 800,30" fill="none" stroke="var(--color-accent)" stroke-width="1" opacity="0.3"/>
    </svg>

    <div class="hero-content">
      <div class="hero-visual">
        <div class="profile-frame">
          <img src="/img/self-portrait.jpg" alt="Ajam Jamaludin" class="profile-img" />
        </div>
      </div>
      <p class="hero-eyebrow">Geophysics Researcher</p>
      <h1 class="hero-title">Ajam Jamaludin</h1>
      <p class="hero-subtitle">
        Computational seismology and earthquake early warning systems.<br />
        Based at Universitas Gadjah Mada, Yogyakarta.
      </p>
      <div class="hero-actions">
        <a href="/blog" class="btn btn--primary">Read Blog</a>
        <a href="/projects" class="btn btn--outline">View Research</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 80vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: calc(var(--space-3xl) + 60px) var(--space-md) var(--space-3xl);
    background: var(--color-bg);
    position: relative;
  }

  .hero-inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .hero-visual {
    margin-bottom: var(--space-xl);
    display: flex;
    justify-content: center;
  }

  .profile-frame {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--color-accent);
    padding: 6px;
    background: var(--color-bg);
    box-shadow: 0 0 30px var(--color-accent-glow);
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(0.2) contrast(1.1);
  }

  .hero-waveform {
    position: absolute;
    top: 60px;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    max-width: 600px;
    height: 60px;
    opacity: 0.25;
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-md);
  }

  .hero-title {
    font-size: clamp(2.25rem, 5vw, 3.5rem);
    font-weight: 500;
    line-height: 1.15;
    margin-bottom: var(--space-lg);
    letter-spacing: -0.02em;
  }

  .hero-subtitle {
    font-size: clamp(1rem, 2vw, 1.125rem);
    color: var(--color-text-muted);
    line-height: 1.7;
    max-width: 480px;
    margin: 0 auto var(--space-xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 640px) {
    .hero-section {
      min-height: 70vh;
      padding-top: calc(80px + var(--space-xl));
    }

    .hero-waveform {
      display: none;
    }
  }
</style>
