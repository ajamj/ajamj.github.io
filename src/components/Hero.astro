---
import { Image } from 'astro:assets';
import portrait from '../assets/self-portrait.jpg';
---

<section id="hero" class="hero-section" aria-labelledby="hero-title">
  <div class="hero-inner">
    <!-- Subtle waveform motif -->
    <svg class="hero-waveform" viewBox="0 0 800 60" preserveAspectRatio="none" aria-hidden="true">
      <path d="M0,30 C40,30 60,10 100,30 C140,50 160,30 200,30 C240,30 260,10 300,30 C340,50 360,30 400,30 C440,30 460,10 500,30 C540,50 560,30 600,30 C640,30 660,10 700,30 C740,50 760,30 800,30" fill="none" stroke="var(--color-accent)" stroke-width="1" opacity="0.3"/>
    </svg>

    <div class="hero-content">
      <div class="hero-visual">
        <div class="profile-frame">
          <Image 
            src={portrait} 
            alt="Ajam Jamaludin" 
            width={280} 
            height={280}
            loading="eager"
            decoding="async"
            class="profile-img" 
          />
        </div>
      </div>
      <p class="hero-eyebrow">Geophysics Researcher</p>
      <h1 id="hero-title" class="hero-title">Ajam Jamaludin</h1>
      <p class="hero-subtitle">
        Computational seismology and earthquake early warning systems.<br />
        Based at Universitas Gadjah Mada, Yogyakarta.
      </p>
      <div class="hero-actions">
        <a href="/blog" class="btn btn--primary">Read Blog</a>
        <a href="/projects" class="btn btn--outline">View Research</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: clamp(60vh, 80vh, 900px);
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--space-section-padding) var(--space-md);
    background: var(--color-bg);
    position: relative;
    overflow: hidden;
  }

  .hero-inner {
    max-width: var(--max-width-wide);
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .hero-visual {
    margin-bottom: var(--space-lg);
    display: flex;
    justify-content: center;
  }

  .profile-frame {
    width: clamp(110px, 15vw, 140px);
    height: clamp(110px, 15vw, 140px);
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--color-accent);
    padding: 6px;
    background: var(--color-bg);
    box-shadow: 0 0 20px var(--color-accent-glow);
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 50%;
    filter: grayscale(0.1) contrast(1.05);
  }

  .hero-waveform {
    position: absolute;
    top: 10%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    max-width: 600px;
    height: 60px;
    opacity: 0.2;
    pointer-events: none;
  }

  .hero-eyebrow {
    font-size: 0.8125rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-sm);
  }

  .hero-title {
    font-size: var(--font-size-h1);
    font-weight: 600;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    letter-spacing: -0.02em;
    color: var(--color-text);
  }

  .hero-subtitle {
    font-size: var(--font-size-body);
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto var(--space-xl);
  }

  .hero-actions {
    display: flex;
    gap: var(--space-md);
    justify-content: center;
    flex-wrap: wrap;
  }

  @media (max-width: 480px) {
    .hero-actions {
      flex-direction: column;
      align-items: stretch;
    }

    .hero-actions .btn {
      width: 100%;
      justify-content: center;
    }
  }

  @media (max-width: 768px) {
    .hero-section {
      padding-top: 100px;
    }
  }
</style>
