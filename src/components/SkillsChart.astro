---
// SkillsChart.astro — Technical stack with obsidian-emerald aesthetic
const skillGroups = [
  { 
    category: 'Programming', 
    items: ['Python', 'MATLAB', 'SQL', 'Bash'],
    hud: 'SYSTEM ARCHITECTURE'
  },
  { 
    category: 'Geophysical Tools', 
    items: ['ObsPy', 'SeisComP', 'SEED/MiniSEED', 'Waveform Viz'],
    hud: 'DOMAIN EXPERTISE'
  },
  { 
    category: 'Analysis', 
    items: ['Machine Learning', 'Signal Processing', 'Statistical Analysis'],
    hud: 'COMPUTATIONAL RESEARCH'
  },
];

const barSkills = [
  { name: 'Python', level: '95%' },
  { name: 'ObsPy', level: '85%' },
  { name: 'MATLAB', level: '80%' },
  { name: 'SeisComP', level: '70%' },
];
---

<div class="skills-container">
  <div class="skills-grid">
    {skillGroups.map((group) => (
      <div class="skill-group glass-card">
        <div class="card-hud hud-label">{group.hud}</div>
        <h3>{group.category}</h3>
        <ul class="skill-list">
          {group.items.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>

  <div class="skills-bars glass-card">
    <div class="card-hud hud-label">PROFICIENCY METRICS</div>
    <h3>Core Competencies</h3>
    <div class="bars-list">
      {barSkills.map((skill) => (
        <div class="skill-bar">
          <div class="bar-info">
            <span class="skill-name">{skill.name}</span>
            <span class="skill-level hud-label">{skill.level}</span>
          </div>
          <div class="bar-bg">
            <div class="bar-fill" style={`width: ${skill.level}`}></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .skills-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .skills-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-xl);
  }

  .skill-group {
    padding: var(--space-xl);
  }

  .skill-group h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-lg);
    color: var(--color-accent);
  }

  .skill-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .skill-list li {
    padding: var(--space-xs) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: 0.95rem;
    opacity: 0.85;
  }

  .skill-list li:last-child {
    border-bottom: none;
  }

  .skills-bars {
    padding: var(--space-xl);
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .skills-bars h3 {
    margin-bottom: var(--space-xl);
  }

  .skill-bar {
    margin-bottom: var(--space-lg);
  }

  .bar-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-xs);
  }

  .skill-name {
    font-family: var(--font-heading);
    font-weight: 500;
    color: var(--color-accent);
  }

  .bar-bg {
    height: 6px;
    background: rgba(16, 185, 129, 0.1);
    border-radius: var(--radius-full);
    overflow: hidden;
  }

  .bar-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--color-accent), #6ffbbe);
    box-shadow: 0 0 10px var(--color-accent-glow);
    border-radius: var(--radius-full);
    transition: width 1s ease-out;
  }
</style>
