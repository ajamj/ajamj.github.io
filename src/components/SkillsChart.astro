---
// SkillsChart.astro — Visual skill icons and simple bar chart
---

<section class="skills-chart">
  <h2 class="section-title">Skills</h2>
  <div class="skills-icons">
    <div class="skill-icon" title="Python">
      <img src="/public/icons/python.svg" alt="Python" />
      <span>Python</span>
    </div>
    <div class="skill-icon" title="MATLAB">
      <img src="/public/icons/matlab.svg" alt="MATLAB" />
      <span>MATLAB</span>
    </div>
    <div class="skill-icon" title="ObsPy">
      <img src="/public/icons/obspy.svg" alt="ObsPy" />
      <span>ObsPy</span>
    </div>
    <div class="skill-icon" title="SeisComP">
      <img src="/public/icons/seiscomp.svg" alt="SeisComP" />
      <span>SeisComP</span>
    </div>
    <div class="skill-icon" title="SQL">
      <img src="/public/icons/sql.svg" alt="SQL" />
      <span>SQL</span>
    </div>
    <div class="skill-icon" title="Bash">
      <img src="/public/icons/bash.svg" alt="Bash" />
      <span>Bash</span>
    </div>
  </div>
  <div class="skills-bars">
    <div class="skill-bar">
      <span>Python</span>
      <div class="bar-bg"><div class="bar-fill" style="width: 95%"></div></div>
    </div>
    <div class="skill-bar">
      <span>MATLAB</span>
      <div class="bar-bg"><div class="bar-fill" style="width: 80%"></div></div>
    </div>
    <div class="skill-bar">
      <span>ObsPy</span>
      <div class="bar-bg"><div class="bar-fill" style="width: 85%"></div></div>
    </div>
    <div class="skill-bar">
      <span>SeisComP</span>
      <div class="bar-bg"><div class="bar-fill" style="width: 70%"></div></div>
    </div>
    <div class="skill-bar">
      <span>SQL</span>
      <div class="bar-bg"><div class="bar-fill" style="width: 75%"></div></div>
    </div>
    <div class="skill-bar">
      <span>Bash</span>
      <div class="bar-bg"><div class="bar-fill" style="width: 65%"></div></div>
    </div>
  </div>
</section>

<style>
.skills-chart {
  padding: 3rem 1rem;
  background: var(--color-bg, #f8fafc);
}
.section-title {
  font-size: 2rem;
  font-weight: 700;
  margin-bottom: 2rem;
  text-align: center;
}
.skills-icons {
  display: flex;
  flex-wrap: wrap;
  gap: 2rem;
  justify-content: center;
  margin-bottom: 2.5rem;
}
.skill-icon {
  display: flex;
  flex-direction: column;
  align-items: center;
  font-size: 1rem;
  color: #334155;
  gap: 0.5rem;
}
.skill-icon img {
  width: 48px;
  height: 48px;
  margin-bottom: 0.25rem;
}
.skills-bars {
  max-width: 500px;
  margin: 0 auto;
}
.skill-bar {
  display: flex;
  align-items: center;
  margin-bottom: 1.25rem;
  gap: 1rem;
}
.skill-bar span {
  min-width: 80px;
  font-weight: 600;
  color: #6366f1;
}
.bar-bg {
  flex: 1;
  background: #e0e7ff;
  border-radius: 0.5rem;
  height: 1.1rem;
  overflow: hidden;
}
.bar-fill {
  background: linear-gradient(90deg, #6366f1 60%, #818cf8 100%);
  height: 100%;
  border-radius: 0.5rem 0 0 0.5rem;
  transition: width 0.7s cubic-bezier(.4,0,.2,1);
}
</style>
