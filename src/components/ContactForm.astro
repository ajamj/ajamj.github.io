---
// ContactForm.astro — Professional contact form and social links
---

<div class="contact-container glass-card scroll-reveal">
  <div class="card-hud hud-label">SECURE CHANNEL: PENDING</div>
  <form class="contact-form" name="contact" method="POST" data-netlify="true" aria-label="Contact form">
    <input type="hidden" name="form-name" value="contact" />
    
    <div class="input-group">
      <label for="name" class="hud-label">Name</label>
      <input id="name" name="name" type="text" required autocomplete="name" placeholder="Full Name" />
    </div>

    <div class="input-group">
      <label for="email" class="hud-label">Email</label>
      <input id="email" name="email" type="email" required autocomplete="email" placeholder="Email Address" />
    </div>

    <div class="input-group">
      <label for="message" class="hud-label">Message</label>
      <textarea id="message" name="message" rows="5" required placeholder="Project inquiry or research collaboration..."></textarea>
    </div>

    <button type="submit" class="btn-animated">Transmit Message</button>
  </form>

  <div class="contact-footer">
    <div class="hud-label">EXTERNAL LINKS</div>
    <div class="contact-social">
      <a href="mailto:jamaludinajam@gmail.com" aria-label="Email" class="contact-icon">
        Email
      </a>
      <a href="https://linkedin.com/in/ajam-jamaludin-56599a202" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="contact-icon">
        LinkedIn
      </a>
      <a href="https://github.com/ajamj" target="_blank" rel="noopener noreferrer" aria-label="GitHub" class="contact-icon">
        GitHub
      </a>
    </div>
  </div>
</div>

<style>
  .contact-container {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-2xl);
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-xl);
    margin-bottom: var(--space-2xl);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .contact-form input,
  .contact-form textarea {
    background: var(--color-surface-low);
    border: none;
    border-bottom: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: var(--space-md);
    font-size: 1rem;
    font-family: var(--font-body);
    color: var(--color-text);
    transition: all 0.2s ease;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    background: var(--color-surface);
    border-bottom-color: var(--color-accent);
    box-shadow: 0 4px 12px var(--color-accent-glow);
  }

  .contact-form button {
    width: 100%;
    margin-top: var(--space-md);
  }

  .contact-footer {
    padding-top: var(--space-xl);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .contact-social {
    display: flex;
    gap: var(--space-xl);
    justify-content: center;
    margin-top: var(--space-md);
  }

  .contact-icon {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    opacity: 0.7;
    transition: all 0.2s ease;
  }

  .contact-icon:hover {
    color: var(--color-accent);
    opacity: 1;
    text-shadow: 0 0 10px var(--color-accent-glow);
  }

  @media (max-width: 600px) {
    .contact-container {
      padding: var(--space-xl);
    }
  }
</style>
