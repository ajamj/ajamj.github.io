---
// ContactForm.astro — Professional contact form and social links
---

<div class="contact-container glass-card scroll-reveal">
  <div class="card-hud hud-label">SECURE CHANNEL: PENDING</div>
  <form class="contact-form" name="contact" method="POST" data-netlify="true" aria-label="Contact form">
    <input type="hidden" name="form-name" value="contact" />
    
    <!-- Honeypot anti-spam field -->
    <p class="hidden">
      <label>Don’t fill this out if you’re human: <input name="bot-field" /></label>
    </p>

    <div class="input-group">
      <label for="name" class="hud-label">Name</label>
      <input id="name" name="name" type="text" required autocomplete="name" placeholder="Full Name" maxlength="100" />
    </div>

    <div class="input-group">
      <label for="email" class="hud-label">Email</label>
      <input id="email" name="email" type="email" required autocomplete="email" placeholder="Email Address" maxlength="100" />
    </div>

    <div class="input-group">
      <label for="message" class="hud-label">Message</label>
      <textarea id="message" name="message" rows="5" required placeholder="Project inquiry or research collaboration..." maxlength="1000"></textarea>
    </div>

    <button type="submit" class="btn btn--primary">Transmit Message</button>
  </form>

  <div class="contact-footer">
    <div class="hud-label">EXTERNAL LINKS</div>
    <nav class="contact-social" aria-label="Social links">
      <a href="mailto:jamaludinajam@gmail.com" aria-label="Email Ajam Jamaludin" class="contact-icon">
        Email
      </a>
      <a href="https://linkedin.com/in/ajam-jamaludin-56599a202" target="_blank" rel="noopener noreferrer" aria-label="Visit Ajam Jamaludin's LinkedIn profile" class="contact-icon">
        LinkedIn
      </a>
      <a href="https://github.com/ajamj" target="_blank" rel="noopener noreferrer" aria-label="Visit Ajam Jamaludin's GitHub profile" class="contact-icon">
        GitHub
      </a>
    </nav>
  </div>
</div>

<style>
  .contact-container {
    max-width: 600px;
    margin: 0 auto;
    padding: var(--space-xl);
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }

  .hidden {
    display: none;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
    margin-bottom: var(--space-xl);
  }

  .input-group {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .contact-form input,
  .contact-form textarea {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.875rem;
    font-size: 1rem;
    font-family: var(--font-body);
    color: var(--color-text);
    transition: all var(--transition);
  }

  .contact-form textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact-form input:focus,
  .contact-form textarea:focus {
    outline: none;
    background: rgba(255, 255, 255, 0.05);
    border-color: var(--color-accent);
    box-shadow: 0 0 15px var(--color-accent-glow);
  }

  .contact-form button {
    width: 100%;
    margin-top: var(--space-md);
    padding: 1rem;
    font-size: 1rem;
  }

  .contact-footer {
    padding-top: var(--space-lg);
    border-top: 1px solid var(--color-border);
    text-align: center;
  }

  .contact-social {
    display: flex;
    gap: var(--space-xl);
    justify-content: center;
    margin-top: 0.75rem;
  }

  .contact-icon {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-text-muted);
    transition: all var(--transition);
    text-decoration: none;
    min-height: 44px;
    display: flex;
    align-items: center;
  }

  .contact-icon:hover {
    color: var(--color-accent);
    text-shadow: 0 0 10px var(--color-accent-glow);
  }

  @media (max-width: 480px) {
    .contact-social {
      flex-direction: column;
      gap: 0.5rem;
      align-items: center;
    }
  }
</style>
