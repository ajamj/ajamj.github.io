---
// ProjectGallery.astro — Technical research project showcase
const projects = [
  {
    title: 'Earthquake Early Warning System (EEWS)',
    description: 'Developed ensemble ML-based EEWS prototype with real-time P-wave detection and magnitude estimation using ObsPy and FDSN client. Achieved MAE ≈ 0.42 against BMKG catalog.',
    tags: ['Python', 'ObsPy', 'Machine Learning', 'Seismic Processing'],
    category: 'COMPUTATIONAL SEISMOLOGY'
  },
  {
    title: 'Thesis: ML-Based Earthquake Parameter Estimation',
    description: 'Performance evaluation of ensemble ML-based early warning system analyzing input duration and station location effects on model generalization using real seismic data.',
    tags: ['Python', 'Machine Learning', 'Seismic Analysis'],
    category: 'RESEARCH THESIS'
  },
  {
    title: 'Real-time Seismic Monitoring Dashboard',
    description: 'PyQt5 GUI with Folium-based real-time mapping and Telegram Bot API for automated earthquake alerts at BMKG.',
    tags: ['Python', 'PyQt5', 'Folium', 'Telegram API'],
    category: 'MONITORING TOOLS'
  },
];
---

<div class="gallery-grid">
  {projects.map((project) => (
    <article class="project-card glass-card card-hover" tabindex="0">
      <div class="card-hud hud-label">{project.category}</div>
      <div class="project-content">
        <h3>{project.title}</h3>
        <p>{project.description}</p>
        <div class="tags">
          {project.tags.map((tag) => (
            <span class="project-tag">{tag}</span>
          ))}
        </div>
      </div>
    </article>
  ))}
</div>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--space-xl);
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 var(--space-md);
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-xl);
    min-height: 320px;
    border-top: 2px solid transparent;
  }

  .project-card:hover {
    border-top-color: var(--color-accent);
  }

  .card-hud {
    margin-bottom: var(--space-sm);
  }

  .project-card h3 {
    font-size: 1.5rem;
    margin-bottom: var(--space-md);
    color: var(--color-accent);
  }

  .project-card p {
    font-size: 0.95rem;
    line-height: 1.6;
    opacity: 0.85;
    margin-bottom: var(--space-xl);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-top: auto;
  }

  .project-tag {
    font-family: var(--font-heading);
    font-size: 0.7rem;
    padding: 0.2rem 0.6rem;
    background: rgba(16, 185, 129, 0.1);
    color: var(--color-accent);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
</style>
