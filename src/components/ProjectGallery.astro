---
// ProjectGallery.astro — Technical research project showcase
const projects = [
  {
    title: 'Gempa.jl: High-Performance Seismology',
    description: 'A modern framework in pure Julia for seismic signal processing, phase picking, and earthquake location. Outperforms traditional tools with 20x speedups in filtering and FFT operations.',
    tags: ['Julia', 'Seismic DSP', 'High-Performance', 'Open Source'],
    category: 'TECHNICAL FRAMEWORK',
    url: 'https://github.com/ajamj/Gempa.jl'
  },
  {
    title: 'Earthquake Early Warning System (EEWS)',
    description: 'Developed ensemble ML-based EEWS prototype with real-time P-wave detection and magnitude estimation using ObsPy and FDSN client. Achieved MAE ≈ 0.42 against BMKG catalog.',
    tags: ['Python', 'ObsPy', 'Machine Learning', 'Seismic Processing'],
    category: 'COMPUTATIONAL SEISMOLOGY'
  },
  {
    title: 'Thesis: ML-Based Earthquake Parameter Estimation',
    description: 'Performance evaluation of ensemble ML-based early warning system analyzing input duration and station location effects on model generalization using real seismic data.',
    tags: ['Python', 'Machine Learning', 'Seismic Analysis'],
    category: 'RESEARCH THESIS'
  },
  {
    title: 'Real-time Seismic Monitoring Dashboard',
    description: 'PyQt5 GUI with Folium-based real-time mapping and Telegram Bot API for automated earthquake alerts at BMKG.',
    tags: ['Python', 'PyQt5', 'Folium', 'Telegram API'],
    category: 'MONITORING TOOLS'
  },
];
---

<div class="gallery-grid" role="list">
  {projects.map((project) => (
    <article class="project-card glass-card card-hover" tabindex="0" role="listitem">
      <div class="card-hud hud-label">{project.category}</div>
      <div class="project-content">
        <h3>{project.title}</h3>
        <p>{project.description}</p>
        <div class="tags">
          {project.tags.map((tag) => (
            <span class="project-tag">{tag}</span>
          ))}
        </div>
        {project.url && (
          <div class="project-footer">
            <a href={project.url} target="_blank" rel="noopener noreferrer" class="contact-icon">View Repository →</a>
          </div>
        )}
      </div>
    </article>
  ))}
</div>

<style>
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: var(--space-lg);
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    min-height: 300px;
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all var(--transition);
  }

  .project-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 20px var(--color-accent-glow);
    transform: translateY(-4px);
  }

  .card-hud {
    margin-bottom: var(--space-sm);
    font-size: 0.75rem;
  }

  .project-card h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
    color: var(--color-accent);
    line-height: 1.3;
  }

  .project-card p {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: auto;
    margin-bottom: var(--space-md);
  }

  .project-tag {
    font-family: var(--font-body);
    font-size: 0.7rem;
    padding: 0.25rem 0.6rem;
    background: var(--color-accent-subtle);
    color: var(--color-accent);
    border: 1px solid var(--color-border-light);
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }

  .project-footer {
    display: flex;
    justify-content: flex-end;
  }

  @media (max-width: 600px) {
    .project-card {
      padding: var(--space-md);
    }
  }
</style>
