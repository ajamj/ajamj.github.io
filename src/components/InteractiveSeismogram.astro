---
// InteractiveSeismogram.astro — D3-powered interactive seismic wave visualization
---

<div class="viz-wrapper glass-card">
  <div class="viz-header">
    <div class="hud-label">SENSOR: UGM-01-SZ | VELOCITY (M/S)</div>
    <div class="viz-controls">
      <button id="reset-zoom" class="hud-btn">RESET</button>
    </div>
  </div>
  <div id="seismogram-container" class="seismogram-container">
    <svg id="seismogram-svg"></svg>
    <div id="tooltip" class="viz-tooltip hud-label"></div>
  </div>
  <div class="viz-footer hud-label">
    <span id="coord-display">TIME: 0.00s | AMP: 0.0000</span>
  </div>
</div>

<style>
  .viz-wrapper {
    width: 100%;
    margin-bottom: var(--space-xl);
    padding: var(--space-lg);
    background: rgba(13, 115, 119, 0.05);
  }

  .viz-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-md);
  }

  .seismogram-container {
    position: relative;
    width: 100%;
    height: 250px;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    overflow: hidden;
    cursor: crosshair;
  }

  #seismogram-svg {
    width: 100%;
    height: 100%;
  }

  .viz-footer {
    margin-top: var(--space-sm);
    font-size: 0.75rem;
    color: var(--color-accent);
    display: flex;
    justify-content: flex-end;
  }

  .hud-btn {
    background: transparent;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    font-family: var(--font-heading);
    font-size: 0.7rem;
    padding: 0.2rem 0.5rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .hud-btn:hover {
    background: var(--color-accent);
    color: var(--color-bg);
  }

  .viz-tooltip {
    position: absolute;
    top: 10px;
    left: 10px;
    background: rgba(11, 19, 38, 0.8);
    padding: 0.3rem 0.6rem;
    border: 1px solid var(--color-accent);
    pointer-events: none;
    display: none;
    z-index: 10;
  }

  :global(.axis path),
  :global(.axis line) {
    stroke: rgba(218, 226, 253, 0.2);
  }

  :global(.axis text) {
    fill: rgba(218, 226, 253, 0.5);
    font-size: 10px;
    font-family: var(--font-heading);
  }

  :global(.wave-line) {
    fill: none;
    stroke: var(--color-accent);
    stroke-width: 1.5;
    pointer-events: none;
  }

  :global(.zoom-rect) {
    fill: none;
    pointer-events: all;
  }
</style>

<script>
  import * as d3 from 'd3';

  function initViz() {
    const container = document.getElementById('seismogram-container');
    const svg = d3.select('#seismogram-svg');
    const tooltip = d3.select('#tooltip');
    const coordDisplay = document.getElementById('coord-display');
    const resetBtn = document.getElementById('reset-zoom');

    if (!container || !svg.node()) return;

    // Data Generation
    const n = 1000;
    const data = Array.from({ length: n }, (_, i) => {
      const t = i / 100;
      // Synthetic seismic wave: noise + signal
      let amp = (Math.random() - 0.5) * 0.1;
      
      // P-wave arrival at 3.0s
      if (t > 3.0 && t < 3.5) {
        amp += Math.sin((t - 3.0) * 100) * 0.5 * Math.exp(-(t - 3.0) * 5);
      }
      
      // S-wave arrival at 5.5s
      if (t > 5.5) {
        amp += Math.sin((t - 5.5) * 40) * 1.2 * Math.exp(-(t - 5.5) * 1.5);
      }

      return { t, amp };
    });

    const margin = { top: 20, right: 30, bottom: 40, left: 50 };
    
    function render() {
      const width = container.clientWidth - margin.left - margin.right;
      const height = container.clientHeight - margin.top - margin.bottom;

      svg.selectAll('*').remove();

      const g = svg.append('g')
        .attr('transform', `translate(${margin.left},${margin.top})`);

      const x = d3.scaleLinear()
        .domain([0, 10])
        .range([0, width]);

      const y = d3.scaleLinear()
        .domain([-2, 2])
        .range([height, 0]);

      const xAxis = d3.axisBottom(x).ticks(10).tickFormat(d => `${d}s`);
      const yAxis = d3.axisLeft(y).ticks(5);

      const gX = g.append('g')
        .attr('class', 'axis x-axis')
        .attr('transform', `translate(0,${height})`)
        .call(xAxis);

      const gY = g.append('g')
        .attr('class', 'axis y-axis')
        .call(yAxis);

      const line = d3.line()
        .x(d => x(d.t))
        .y(d => y(d.amp))
        .curve(d3.curveMonotoneX);

      const path = g.append('path')
        .datum(data)
        .attr('class', 'wave-line')
        .attr('d', line);

      // Zooming
      const zoom = d3.zoom()
        .scaleExtent([1, 100])
        .extent([[0, 0], [width, height]])
        .on('zoom', (event) => {
          const newX = event.transform.rescaleX(x);
          gX.call(xAxis.scale(newX));
          path.attr('d', line.x(d => newX(d.t)));
        });

      svg.append('rect')
        .attr('class', 'zoom-rect')
        .attr('width', width)
        .attr('height', height)
        .attr('transform', `translate(${margin.left},${margin.top})`)
        .call(zoom);

      // Interaction
      svg.on('mousemove', (event) => {
        const [mx, my] = d3.pointer(event);
        const tx = x.invert(mx - margin.left);
        const ty = y.invert(my - margin.top);
        
        if (coordDisplay) {
          coordDisplay.textContent = `TIME: ${tx.toFixed(2)}s | AMP: ${ty.toFixed(4)}`;
        }
      });

      resetBtn?.addEventListener('click', () => {
        svg.transition().duration(750).call(zoom.transform, d3.zoomIdentity);
      });
    }

    render();
    window.addEventListener('resize', render);
  }

  // Initialize on page load
  document.addEventListener('astro:page-load', initViz);
  // Fallback for initial load
  initViz();
</script>
