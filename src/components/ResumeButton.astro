---
// ResumeButton.astro — Downloadable CV/resume button
---

<a href="/Ajam-Jamaludin-CV.pdf" download class="resume-btn" aria-label="Download CV as PDF">
  <span>Download CV</span>
  <svg width="16" height="16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <path d="M8 1v10m0 0L5 8m3 3l3-3M2 14h12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>
</a>

<style>
.resume-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.5rem;
  background: var(--color-accent);
  color: #fff;
  font-weight: 500;
  font-size: 0.875rem;
  letter-spacing: 0.02em;
  border: none;
  border-radius: var(--radius);
  padding: 0.625rem 1.25rem;
  text-decoration: none;
  transition: background 0.2s ease;
}

.resume-btn:hover {
  background: var(--color-accent-light);
  text-decoration: none;
  color: #fff;
}

.resume-btn svg {
  opacity: 0.8;
}
</style>
