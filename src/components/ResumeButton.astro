---
// ResumeButton.astro — Prominent downloadable CV/resume button
---

<section class="resume-section">
  <a href="/Ajam-Jamaludin-CV.pdf" download class="resume-btn btn-animated" aria-label="Download CV as PDF">
    <span>Download CV</span>
    <svg width="22" height="22" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false"><path d="M11 2v13m0 0l-4-4m4 4l4-4M4 18h14" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
  </a>
</section>

<style>
.resume-section {
  display: flex;
  justify-content: center;
  margin: 2.5rem 0 3.5rem 0;
}
.resume-btn {
  display: inline-flex;
  align-items: center;
  gap: 0.75rem;
  background: linear-gradient(90deg, #6366f1 60%, #818cf8 100%);
  color: #fff;
  font-weight: 700;
  border: none;
  border-radius: 0.75rem;
  padding: 1.1rem 2.2rem;
  font-size: 1.15rem;
  text-decoration: none;
  box-shadow: 0 2px 12px rgba(99,102,241,0.10);
  transition: background 0.18s, box-shadow 0.18s, transform 0.18s;
}
.resume-btn svg {
  display: inline-block;
  vertical-align: middle;
}
</style>
