---
// BlogPreview.astro — Technical research blog/insights section preview
import { getCollection } from 'astro:content';

const latestPosts = (await getCollection('blog'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 2);
---

<section id="blog" class="blog-section scroll-reveal" aria-labelledby="blog-title">
  <div class="container">
    <div class="section-header">
      <h2 id="blog-title" class="section-title text-center">Technical Research Blog</h2>
      <p class="section-subtitle hud-label text-center">Insights into Computational Geophysics</p>
    </div>

    <div class="blog-grid" role="list">
      {latestPosts.map((post) => (
        <article class="blog-card glass-card card-hover" role="listitem">
          <div class="card-hud hud-label">TOPIC: {post.data.tags[0] || 'RESEARCH'}</div>
          <h3>{post.data.title}</h3>
          <p class="blog-summary">
            {post.data.description}
          </p>
          <div class="blog-footer">
            <a href={`/blog/${post.slug}`} class="btn-animated">Read Full Article</a>
          </div>
        </article>
      ))}

      {latestPosts.length === 1 && (
        <article class="blog-card glass-card card-hover" role="listitem">
          <div class="card-hud hud-label">TOPIC: MACHINE LEARNING</div>
          <h3>Ensemble ML in Early Warning Systems</h3>
          <p class="blog-summary">
            Technical breakdown of how multi-model voting enhances P-wave detection reliability in the BMKG EEWS prototype.
          </p>
          <div class="blog-footer">
            <a href="#" class="btn-animated">Coming Soon</a>
          </div>
        </article>
      )}
    </div>

    <div class="blog-view-all">
      <a href="/blog" class="contact-icon">View All Insights →</a>
    </div>
  </div>
</section>

<style>
  .blog-section {
    padding: var(--space-section-padding) 0;
    background-color: var(--color-bg);
  }

  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr));
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }

  .blog-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-lg);
    min-height: 280px;
    background: var(--color-surface);
    backdrop-filter: blur(12px);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    transition: all var(--transition);
  }

  .blog-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 0 20px var(--color-accent-glow);
    transform: translateY(-4px);
  }

  .card-hud {
    margin-bottom: var(--space-sm);
    font-size: 0.75rem;
  }

  .blog-card h3 {
    font-size: 1.25rem;
    margin-bottom: var(--space-sm);
    color: var(--color-accent);
  }

  .blog-summary {
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--color-text-muted);
    margin-bottom: var(--space-lg);
    flex-grow: 1;
  }

  .blog-footer {
    display: flex;
    justify-content: flex-end;
  }

  .blog-view-all {
    margin-top: var(--space-2xl);
    text-align: center;
  }

  .contact-icon {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-accent);
    transition: all var(--transition);
    text-decoration: none;
  }

  .contact-icon:hover {
    text-shadow: 0 0 10px var(--color-accent-glow);
  }

  @media (max-width: 600px) {
    .blog-card {
      padding: var(--space-md);
    }
  }
</style>
